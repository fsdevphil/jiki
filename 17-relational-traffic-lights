let red = "red"
let yellow = "amber"
let green = "green"
let housingColor = "charcoal"
let center = 50
let radius = 10

let yellowY = center // 50
let redY = center - (radius * 2) // 30
let greenY = center + (radius * 2) // 70
let housingX = center - (radius * 2) // 30
let housingY = center - (radius * 4) // 10
let housingWidth = radius * 4 // 40
let housingHeight = radius * 8 // 80

rectangle(housingX, housingY, housingWidth, housingHeight, housingColor)

circle(center, redY, radius, red)
circle(center, yellowY, radius, yellow)
circle(center, greenY, radius, green)

// Build the skyscraper

let numberOfFloors = numFloors()
let center = 19
let ground = 2

// Build the ground floor

buildWall(center - 2, ground)
buildGlass(center - 1, ground)
buildEntrance(center, ground)
buildGlass(center + 1, ground)
buildWall(center + 2, ground)

// Build the glass floors

repeat(numberOfFloors - 1) {
  buildWall(center - 2, ground + 1)
  buildGlass(center - 1, ground + 1)
  buildGlass(center, ground + 1)
  buildGlass(center + 1, ground + 1)
  buildWall(center + 2, ground + 1)
  ground = ground + 1
}

// Build the roof

repeat(5) {
  buildWall(center - 2, ground + 1)
  center = center + 1
}

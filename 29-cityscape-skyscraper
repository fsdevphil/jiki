// Build the skyscraper
let totalHeight = numFloors()

let x = 19
let y = 2

// Build the ground floor
buildWall(x - 2, y)
buildGlass(x - 1, y)
buildEntrance(x, y)
buildGlass(x + 1, y)
buildWall(x + 2, y)

// Build the glass floors

repeat(totalHeight - 1) {
  y = y + 1
  
  buildWall(x - 2, y)
  buildGlass(x - 1, y)
  buildGlass(x, y)
  buildGlass(x + 1, y)
  buildWall(x + 2, y)
}

// Build the roof

y = y + 1

buildWall(x - 2, y)
buildWall(x - 1, y)
buildWall(x, y)
buildWall(x + 1, y)
buildWall(x + 2, y)
